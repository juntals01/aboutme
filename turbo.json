{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "start": {
      "dependsOn": ["build"]
    },
    "clean": {
      "cache": false
    },
    "reset:all": {
      "cache": false
    },
    "migration:generate": {
      "cache": false
    },
    "migration:run": {
      "cache": false
    },
    "seed:run": {
      "cache": false
    }
  }
}
