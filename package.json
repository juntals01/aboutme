{
  "name": "aboutme",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "(docker compose up -d || true) && turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:api": "turbo run dev --filter=api",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=web",
    "build:api": "turbo run build --filter=api",
    "lint": "turbo run lint",
    "start": "turbo run start",
    "clean": "turbo run clean && rm -rf node_modules",
    "reset:all": "turbo run reset:all --filter=api",
    "migration:generate": "turbo run migration:generate --filter=api",
    "migration:run": "turbo run migration:run --filter=api",
    "seed:run": "turbo run seed:run --filter=api"
  },
  "devDependencies": {
    "turbo": "latest"
  },
  "packageManager": "npm@10.0.0",
  "engines": {
    "node": ">=18"
  }
}
